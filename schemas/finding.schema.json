{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ai-review Finding",
  "description": "A single code review finding from an ai-review agent",
  "type": "object",
  "required": ["file", "line", "agent", "severity", "category", "message", "suggestion"],
  "properties": {
    "file": {
      "type": "string",
      "description": "Relative path to the file from repository root"
    },
    "line": {
      "type": "integer",
      "minimum": 1,
      "description": "Start line number of the issue"
    },
    "endLine": {
      "type": "integer",
      "minimum": 1,
      "description": "End line number of the issue (optional, defaults to line)"
    },
    "agent": {
      "type": "string",
      "enum": ["clean-coder", "tester", "architect", "ddd-reviewer", "performance"],
      "description": "Name of the reviewing agent"
    },
    "severity": {
      "type": "string",
      "enum": ["critical", "warning", "info"],
      "description": "Severity level of the finding"
    },
    "category": {
      "type": "string",
      "description": "Agent-specific category code (e.g. n-plus-one, anemic-domain)"
    },
    "message": {
      "type": "string",
      "description": "Concise description of the problem"
    },
    "suggestion": {
      "type": "string",
      "description": "Specific actionable fix or improvement"
    },
    "fingerprint": {
      "type": "string",
      "description": "SHA256 hash for deduplication (generated by aggregate step)"
    }
  },
  "additionalProperties": false
}
