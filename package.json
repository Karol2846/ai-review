{
  "name": "ai-review",
  "version": "0.1.0",
  "description": "Multi-agent local code review powered by the Vercel AI SDK",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "ai-review": "./dist/cli.js"
  },
  "files": [
    "dist",
    "agents",
    "skill",
    "scripts"
  ],
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean:dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/google": "^3.0.71",
    "@ai-sdk/openai": "^3.0.63",
    "ai": "^6.0.177",
    "chalk": "^5.4.1",
    "execa": "^9.6.0",
    "micromatch": "^4.0.8",
    "p-map": "^7.0.3"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.19.17",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  }
}
