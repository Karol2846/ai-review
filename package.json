{
  "name": "ai-review",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent local code review powered by GitHub Copilot CLI",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "ai-review": "./dist/cli.js"
  },
  "files": [
    "dist",
    "agents"
  ],
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean:dist && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "execa": "^9.6.0",
    "micromatch": "^4.0.8",
    "p-map": "^7.0.3"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.4"
  }
}
