#!/usr/bin/env bash
set -euo pipefail

# ai-review — Multi-Agent Local Code Review
# Usage: ai-review [--annotate] [--clean] [--base <branch>] [--agents <list>]
#        [--severity <min>] [--files <glob>] [--json]

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
AI_REVIEW_HOME="$(cd "$SCRIPT_DIR/.." && pwd)"

# --- Defaults ---
ANNOTATE=false
CLEAN=false
JSON_OUTPUT=false
DEBUG=false
BASE_BRANCH=""
AGENTS="clean-coder,tester,architect,ddd-reviewer,performance"
MIN_SEVERITY="info"
FILE_FILTER=""
MAX_PARALLEL=5
STRICT_MODE=false
BATCH_MODE="off"
BATCH_MAX_CHARS=16000
MAX_FILE_KB=256
INCLUDE_LARGE_FILES=false
RESPONSE_PROFILE="full"
METRICS_OUT=""
SEVERITY_SET=false

# --- Colors ---
RED='\033[0;31m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
GREEN='\033[0;32m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --annotate)  ANNOTATE=true; shift ;;
    --clean)     CLEAN=true; shift ;;
    --json)      JSON_OUTPUT=true; shift ;;
    --debug)     DEBUG=true; shift ;;
    --base)      BASE_BRANCH="$2"; shift 2 ;;
    --agents)    AGENTS="$2"; shift 2 ;;
    --severity)  MIN_SEVERITY="$2"; SEVERITY_SET=true; shift 2 ;;
    --strict)    STRICT_MODE=true; shift ;;
    --batch-mode) BATCH_MODE="$2"; shift 2 ;;
    --batch-max-chars) BATCH_MAX_CHARS="$2"; shift 2 ;;
    --max-file-kb) MAX_FILE_KB="$2"; shift 2 ;;
    --include-large-files) INCLUDE_LARGE_FILES=true; shift ;;
    --response-profile) RESPONSE_PROFILE="$2"; shift 2 ;;
    --metrics-out) METRICS_OUT="$2"; shift 2 ;;
    --files)     FILE_FILTER="$2"; shift 2 ;;
    --parallel)  MAX_PARALLEL="$2"; shift 2 ;;
    --help|-h)
      echo "ai-review — Multi-Agent Local Code Review"
      echo ""
      echo "Usage: ai-review [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --base <branch>    Base branch for diff (default: auto-detect)"
      echo "  --annotate         Insert TODO comments into source files"
      echo "  --clean            Remove previous [ai-review] TODO comments"
      echo "  --agents <list>    Comma-separated agent list (default: all)"
      echo "  --severity <min>   Minimum severity: critical, warning, info (default: info)"
      echo "  --strict           Disable smart routing; run all selected agents for each file"
      echo "  --files <glob>     Filter changed files by glob pattern"
      echo "  --batch-mode <m>   Copilot call strategy: off|agent (default: off)"
      echo "  --batch-max-chars  Max prompt chars per batch in agent mode (default: 16000)"
      echo "  --max-file-kb <n>  Skip files larger than n KB unless --include-large-files (default: 256)"
      echo "  --include-large-files  Include files above --max-file-kb limit"
      echo "  --response-profile Response shaping: full|critical-warning (default: full)"
      echo "  --metrics-out <p>  Write run metrics JSON to this path"
      echo "  --json             Output raw JSON findings"
      echo "  --debug            Show raw agent output and timings for debugging"
      echo "  --parallel <n>     Max parallel agent invocations (default: 5)"
      echo "  -h, --help         Show this help"
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

if [[ "$BATCH_MODE" != "off" && "$BATCH_MODE" != "agent" ]]; then
  echo -e "${RED}Error: --batch-mode must be off or agent${NC}"
  exit 1
fi
if [[ "$RESPONSE_PROFILE" != "full" && "$RESPONSE_PROFILE" != "critical-warning" ]]; then
  echo -e "${RED}Error: --response-profile must be full or critical-warning${NC}"
  exit 1
fi

if [[ "$RESPONSE_PROFILE" == "critical-warning" && "$SEVERITY_SET" == "false" ]]; then
  MIN_SEVERITY="warning"
fi

# --- Validate we're in a git repo ---
if ! git rev-parse --is-inside-work-tree &>/dev/null; then
  echo -e "${RED}Error: Not inside a git repository${NC}"
  exit 1
fi

REPO_ROOT="$(git rev-parse --show-toplevel)"

# --- Clean mode ---
if [[ "$CLEAN" == "true" ]]; then
  echo -e "${CYAN}🧹 Cleaning previous [ai-review] comments...${NC}"
  "$SCRIPT_DIR/annotate.sh" --clean "$REPO_ROOT"
  exit 0
fi

# --- Detect base branch ---
if [[ -z "$BASE_BRANCH" ]]; then
  BASE_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@' || true)
  if [[ -z "$BASE_BRANCH" ]]; then
    # Fallback: try main, then master
    if git rev-parse --verify origin/main &>/dev/null; then
      BASE_BRANCH="main"
    elif git rev-parse --verify origin/master &>/dev/null; then
      BASE_BRANCH="master"
    else
      echo -e "${RED}Error: Cannot detect base branch. Use --base <branch>${NC}"
      exit 1
    fi
  fi
fi

MERGE_BASE=$(git merge-base HEAD "origin/$BASE_BRANCH" 2>/dev/null || true)
if [[ -z "$MERGE_BASE" ]]; then
  echo -e "${RED}Error: Cannot find merge-base with origin/$BASE_BRANCH${NC}"
  exit 1
fi

# --- Get changed files ---
mapfile -t CHANGED_FILES < <(git diff --name-only "$MERGE_BASE"..HEAD)

if [[ ${#CHANGED_FILES[@]} -eq 0 ]]; then
  echo -e "${GREEN}✅ No changes detected against origin/$BASE_BRANCH${NC}"
  exit 0
fi

# Apply file filter
if [[ -n "$FILE_FILTER" ]]; then
  FILTERED=()
  for f in "${CHANGED_FILES[@]}"; do
    # shellcheck disable=SC2254
    if [[ "$f" == $FILE_FILTER ]]; then
      FILTERED+=("$f")
    fi
  done
  CHANGED_FILES=("${FILTERED[@]}")
fi

echo -e "${BOLD}🔍 ai-review${NC} — reviewing ${#CHANGED_FILES[@]} changed files against ${DIM}origin/$BASE_BRANCH${NC}"
echo -e "${DIM}   merge-base: ${MERGE_BASE:0:12}${NC}"
echo ""

# --- Create temp workspace ---
WORKDIR=$(mktemp -d /tmp/ai-review-XXXXXX)
trap 'rm -rf "$WORKDIR"' EXIT

# Save changed files list
printf '%s\n' "${CHANGED_FILES[@]}" > "$WORKDIR/changed-files.txt"

# Generate unified diff
git diff "$MERGE_BASE"..HEAD > "$WORKDIR/full.diff"

# --- Phase 1: Analyze ---
echo -e "${CYAN}📋 Phase 1: Analyzing with agents: ${AGENTS}${NC}"
"$SCRIPT_DIR/analyze.sh" \
  "$REPO_ROOT" \
  "$WORKDIR" \
  "$AGENTS" \
  "$MAX_PARALLEL" \
  "$AI_REVIEW_HOME" \
  "$DEBUG" \
  "$STRICT_MODE" \
  "$BATCH_MODE" \
  "$BATCH_MAX_CHARS" \
  "$MAX_FILE_KB" \
  "$INCLUDE_LARGE_FILES" \
  "$RESPONSE_PROFILE"

# --- Phase 2: Aggregate ---
echo -e "${CYAN}📊 Phase 2: Aggregating findings...${NC}"
"$SCRIPT_DIR/aggregate.sh" "$WORKDIR" "$MIN_SEVERITY"

# --- Debug: show raw agent results ---
if [[ "$DEBUG" == "true" ]]; then
  echo ""
  echo -e "${BOLD}🐛 Debug: Raw agent results${NC}"
  echo -e "${DIM}─────────────────────────────────────────${NC}"
  for f in "$WORKDIR/raw/"*.json; do
    name=$(basename "$f" .json)
    count=$(jq 'length' "$f" 2>/dev/null || echo "?")
    if [[ "$count" -gt 0 ]]; then
      echo -e "  ${GREEN}$name: $count findings${NC}"
    else
      echo -e "  ${DIM}$name: [] (empty)${NC}"
    fi
  done
  echo ""
  echo -e "${DIM}Logs: $WORKDIR/logs/${NC}"
  echo -e "${DIM}Debug output: $WORKDIR/debug/${NC}"
  echo ""
  # Show any errors from logs
  for log in "$WORKDIR/logs/"*.log; do
    [[ -s "$log" ]] || continue
    name=$(basename "$log" .log)
    echo -e "${RED}⚠ Stderr from $name:${NC}"
    cat "$log"
    echo ""
  done
  # Keep workdir alive in debug mode (override trap)
  trap '' EXIT
  echo -e "${DIM}Workdir preserved for inspection: $WORKDIR${NC}"
fi

# --- Count findings ---
TOTAL=$(jq 'length' "$WORKDIR/findings.json")
ANALYZE_METRICS="$WORKDIR/metrics/analyze.json"

if [[ -f "$ANALYZE_METRICS" ]]; then
  CALLS=$(jq -r '.copilot_calls // 0' "$ANALYZE_METRICS")
  PROMPT_TOTAL=$(jq -r '.total_prompt_chars // 0' "$ANALYZE_METRICS")
  PROMPT_AVG=$(jq -r '.avg_prompt_chars // 0' "$ANALYZE_METRICS")
  ANALYZE_RUNTIME=$(jq -r '.runtime_ms // 0' "$ANALYZE_METRICS")
  echo -e "${DIM}📈 Metrics: calls=$CALLS totalPromptChars=$PROMPT_TOTAL avgPromptChars=$(printf '%.0f' "$PROMPT_AVG") runtimeMs=$ANALYZE_RUNTIME findings=$TOTAL${NC}"
  if [[ -n "$METRICS_OUT" ]]; then
    jq --argjson findings "$TOTAL" '. + {dedup_findings: $findings}' "$ANALYZE_METRICS" > "$METRICS_OUT"
    echo -e "${DIM}   metrics written to: $METRICS_OUT${NC}"
  fi
fi

if [[ "$TOTAL" -eq 0 ]]; then
  echo ""
  echo -e "${GREEN}✅ No issues found! Your code looks good.${NC}"
  if [[ "$DEBUG" == "false" ]]; then
    echo -e "${DIM}Tip: run with --debug to inspect raw agent output${NC}"
  fi
  exit 0
fi

CRITICAL=$(jq '[.[] | select(.severity == "critical")] | length' "$WORKDIR/findings.json")
WARNINGS=$(jq '[.[] | select(.severity == "warning")] | length' "$WORKDIR/findings.json")
INFOS=$(jq '[.[] | select(.severity == "info")] | length' "$WORKDIR/findings.json")

echo ""
echo -e "${BOLD}Found $TOTAL issues:${NC} ${RED}$CRITICAL critical${NC} | ${YELLOW}$WARNINGS warning${NC} | ${CYAN}$INFOS info${NC}"
echo ""

# --- Phase 3: Output ---
if [[ "$JSON_OUTPUT" == "true" ]]; then
  jq '.' "$WORKDIR/findings.json"
else
  "$SCRIPT_DIR/report.sh" "$WORKDIR/findings.json"

  if [[ "$ANNOTATE" == "true" ]]; then
    echo ""
    echo -e "${CYAN}📝 Annotating files with TODO comments...${NC}"
    "$SCRIPT_DIR/annotate.sh" --apply "$WORKDIR/findings.json" "$REPO_ROOT"
    echo -e "${GREEN}Done. Use ${BOLD}ai-review --clean${NC}${GREEN} to remove annotations later.${NC}"
  fi
fi
